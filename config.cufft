#!/bin/bash
export BACKEND='cufft'
export ACCELFLAGS='-D _CUFFT_ -acc=gpu,noautopar,verystrict -gpu=cc80,fastmath -Minfo=accel'
export CUDALDFLAGS='-lhefftecufftfortran -lcufft -lcudart -lcuda'
export MKLFLAGS=''
export MKLLDFLAGS=''
export FFTWFLAGS=''
# put '-D _DOUBLE_' here to build with double precision floats
export PRECISION=''
